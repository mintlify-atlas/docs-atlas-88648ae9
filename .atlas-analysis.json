  "keyFeatures": [
    "Personal recipe management with search by name, category, or ingredients",
    "Fridge inventory tracker for organized ingredient storage",
    "Grocery planner that auto-generates shopping lists from selected recipes",
    "AI autofill via Google Gemini — paste a recipe URL to populate the form",
    "Recipe export/import for sharing recipe libraries between users",
    "Randomizer tool to help choose recipes when indecisive",
    "Previous grocery plans history for reference and reuse",
    "JWT-based authentication with HTTP-only cookie refresh tokens",
    "Dark/light theme support",
    "Drag-and-drop ingredient grouping and recipe board ordering"
  ],
